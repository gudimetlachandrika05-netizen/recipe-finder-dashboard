<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Recipe Finder Dashboard</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#f8f9fa;
    min-height:100vh;
}

header{
    background:#ff6b6b;
    color:white;
    text-align:center;
    padding:20px;
    font-size:28px;
    font-weight:bold;
}

.container{
    width:90%;
    margin:auto;
    padding:20px;
}

.search-box{
    display:flex;
    justify-content:center;
    margin-bottom:30px;
}

.search-box input{
    width:60%;
    padding:12px;
    border:2px solid #ddd;
    border-radius:8px 0 0 8px;
    outline:none;
    font-size:16px;
}

.search-box button{
    padding:12px 20px;
    border:none;
    background:#ff6b6b;
    color:white;
    cursor:pointer;
    border-radius:0 8px 8px 0;
}

.recipe-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:20px;
}

.recipe-card{
    background:white;
    border-radius:12px;
    box-shadow:0 4px 10px rgba(0,0,0,0.1);
    overflow:hidden;
    transition:0.3s;
}

.recipe-card:hover{
    transform:scale(1.03);
}

.recipe-card img{
    width:100%;
    height:180px;
    object-fit:cover;
}

.recipe-info{
    padding:15px;
}

.recipe-info h3{
    margin-bottom:10px;
}

.recipe-info p{
    color:gray;
    margin-bottom:10px;
}

.ingredients{
    font-size:14px;
    color:#444;
}
</style>
</head>

<body>

<header>🍲 Recipe Finder Dashboard</header>

<div class="container">

    <div class="search-box">
        <input type="text" id="searchInput" placeholder="Search recipe...">
        <button onclick="searchRecipe()">Search</button>
    </div>

    <div class="recipe-grid" id="recipeGrid"></div>

</div>

<script>

const recipes = [
{
name:"Veg Biryani",
image:"https://images.unsplash.com/photo-1701579231305-d84d8af9a3fd",
description:"Aromatic rice dish with vegetables.",
ingredients:"Rice, Carrot, Beans, Spices"
},

{
name:"Masala Dosa",
image:"https://images.unsplash.com/photo-1668236543090-82eba5ee5976",
description:"South Indian crispy dosa.",
ingredients:"Rice Batter, Potato, Onion"
},

{
name:"Paneer Butter Masala",
image:"https://images.unsplash.com/photo-1631452180519-c014fe946bc7",
description:"Creamy paneer curry.",
ingredients:"Paneer, Tomato, Butter, Cream"
},

{
name:"Pasta",
image:"https://images.unsplash.com/photo-1621996346565-e3dbc646d9a9",
description:"Italian pasta recipe.",
ingredients:"Pasta, Cheese, Tomato Sauce"
}
];

function displayRecipes(recipeArray){
    let grid=document.getElementById("recipeGrid");
    grid.innerHTML="";

    recipeArray.forEach(recipe=>{
        grid.innerHTML+=`
        <div class="recipe-card">
            <img src="${recipe.image}">
            <div class="recipe-info">
                <h3>${recipe.name}</h3>
                <p>${recipe.description}</p>
                <div class="ingredients">
                    <strong>Ingredients:</strong><br>
                    ${recipe.ingredients}
                </div>
            </div>
        </div>
        `;
    });
}

function searchRecipe(){
    let search=document.getElementById("searchInput").value.toLowerCase();

    let filtered=recipes.filter(recipe =>
        recipe.name.toLowerCase().includes(search)
    );

    displayRecipes(filtered);
}

displayRecipes(recipes);

</script>

</body>
</html>
